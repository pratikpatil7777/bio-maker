# ====================================
# Environment Variables for Bio Maker
# ====================================
#
# IMPORTANT: Copy this file to .env.local and fill in your values
# .env.local is gitignored and safe for secrets
# .env.example is committed - NEVER put real keys here!
#
# ====================================

# Groq AI API Key (Required for AI Bio Writer)
# Get your FREE API key from: https://console.groq.com/keys
# Free tier: 30 requests/min, 14,400 requests/day
GROQ_API_KEY=

# ====================================
# Analytics (FREE TIER - All Optional)
# ====================================

# Google Analytics 4 (GA4)
# Get your ID from: https://analytics.google.com
# Steps: Admin > Data Streams > Add Stream > Web > Copy Measurement ID
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Microsoft Clarity (FREE heatmaps & session recordings)
# Get your ID from: https://clarity.microsoft.com
# Steps: Add new project > Copy Project ID from settings
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# ====================================
# Site URL (for SEO)
# ====================================
NEXT_PUBLIC_SITE_URL=https://bio-maker-in.vercel.app

# ====================================
# Google Search Console Verification
# ====================================
# Get this from: https://search.google.com/search-console
# Steps: Add Property > URL prefix > HTML tag method > Copy content value
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ====================================
# WhatsApp Support
# ====================================
# Format: Country code + Number (no spaces, no +)
# Example: 919876543210 (91 = India, then 10-digit number)
NEXT_PUBLIC_WHATSAPP_NUMBER=12019934276
